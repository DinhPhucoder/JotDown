# System files
# -------------------------------------------------------------
.DS_Store
Thumbs.db
*.log
.env
.env.*

# Docker / Infrastructure
# -------------------------------------------------------------
# KHÔNG đẩy dữ liệu thực tế của DB lên Git
docker/mysql_data/
nginx/*.log



# IDE / Editor specific
# -------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Agent / Tooling
# -------------------------------------------------------------
.agent/
.gemini/
.agents/
.claude/
.gitnexus/
.github/instructions/
.history/gitnexus/
skills-lock.json

# Cache / Models
# -------------------------------------------------------------
# HuggingFace embeddings cache (GitNexus)
undefined/.cache/
.cache/
