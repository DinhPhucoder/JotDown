# Cấu hình biến môi trường cho Frontend (Vite)
# Dành cho việc test nội bộ qua mạng LAN hoặc VPN (Ví dụ: IP Radmin VPN hoặc IP Wi-Fi)

# VITE_API_URL trỏ tới máy tính chạy Backend
# Đổi 127.0.0.1 thành IP của máy chạy backend nếu muốn test từ thiết bị khác.
# Ví dụ: VITE_API_URL=http://26.126.178.21:8000/api
VITE_API_URL=http://127.0.0.1:8000/api

# Pusher (WebSocket) configuration
VITE_PUSHER_APP_KEY=your_pusher_app_key
VITE_PUSHER_APP_CLUSTER=your_pusher_app_cluster
